PORT=8787
TIMEZONE=Europe/Skopje
BASE_URL=http://localhost:8787

# Optional shared token to protect webhook endpoint.
# Configure the same value in Setmore webhook headers as x-webhook-token.
WEBHOOK_TOKEN=

# Notification controls
DEFAULT_LANGUAGE=mk
SEND_EMAIL=true
SEND_SMS=true

# Clinic identity
CLINIC_NAME=Dental Rhapsody
CLINIC_PHONE=+38978279493
CLINIC_EMAIL=contact@dentalrhapsody.com.mk

# Email provider (Resend)
RESEND_API_KEY=
EMAIL_FROM=Dental Rhapsody <noreply@dentalrhapsody.com.mk>

# SMS provider (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1XXXXXXXXXX

# Reminder schedule in hours before appointment, comma separated
REMINDER_HOURS=24,2
